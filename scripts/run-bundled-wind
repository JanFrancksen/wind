#!/usr/bin/env bash

# Cargo calls a target runner as: runner <compiled-binary> [application args...].
# CEF on macOS must run from an app bundle, but copying its framework on every
# source edit is expensive. Keep one bundle and refresh just its executables.
set -euo pipefail

app_binary="$1"
shift

# Do not change the behavior of explicitly run utility binaries such as
# `cargo run --bin bundle_wind`.
if [[ "$(basename "$app_binary")" != "wind" ]]; then
  exec "$app_binary" "$@"
fi

repository_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
target_directory="$(dirname "$app_binary")"
bundle="$target_directory/bundle/wind.app"
inputs_file="$bundle/Contents/Resources/.wind-cef-inputs"
# Ad-hoc signing is deterministic for local builds and does not become invalid
# when a cached Apple Development certificate expires. Release-like testing can
# still opt into a specific valid identity explicitly.
codesign_identity="${WIND_CODESIGN_IDENTITY:--}"

build_binary() {
  if [[ "$(basename "$target_directory")" == "release" ]]; then
    cargo build --release --bin "$1"
  else
    cargo build --bin "$1"
  fi
}

bundle_inputs() {
  shasum "$repository_root/Cargo.toml" "$repository_root/Cargo.lock"
  printf 'CEF_PATH=%s\n' "${CEF_PATH:-cargo-managed}"

  if [[ -n "${CEF_PATH:-}" && -e "$CEF_PATH" ]]; then
    stat -f 'CEF_PATH_STAT=%m:%z' "$CEF_PATH"
  fi

  find "$repository_root/assets" -type f -exec shasum {} + | sort
}

inputs_hash="$(bundle_inputs | shasum | awk '{ print $1 }')"

needs_bundle=false
if [[ ! -d "$bundle" || ! -f "$inputs_file" || "$(<"$inputs_file")" != "$inputs_hash" ]]; then
  needs_bundle=true
fi

if "$needs_bundle"; then
  echo "Preparing the CEF app bundle..."
  (
    cd "$repository_root"
    build_binary wind_helper
    build_binary bundle_wind
    "$target_directory/bundle_wind"
  )

  printf '%s\n' "$inputs_hash" > "$inputs_file"
  # `bundle_wind` has already signed every nested component. Refresh only the
  # outer resource seal after writing the inputs marker; asking codesign to
  # immediately deep-resign CEF can fail inside macOS's signing subsystem.
  codesign --force --sign "$codesign_identity" "$bundle"
else
  (
    cd "$repository_root"
    build_binary wind_helper
  )

  cp -f "$app_binary" "$bundle/Contents/MacOS/wind"
  for helper in \
    "wind Helper" \
    "wind Helper (Alerts)" \
    "wind Helper (GPU)" \
    "wind Helper (Plugin)" \
    "wind Helper (Renderer)"; do
    cp -f "$target_directory/wind_helper" \
      "$bundle/Contents/Frameworks/$helper.app/Contents/MacOS/$helper"
    codesign --force --sign "$codesign_identity" \
      "$bundle/Contents/Frameworks/$helper.app"
  done

  # Preserve the already-valid CEF framework signature and reseal the outer
  # app after its executable and helper apps have been refreshed.
  codesign --force --sign "$codesign_identity" "$bundle"
fi

# LaunchServices supplies the bundle metadata that Chromium uses for runtime
# process validation. Executing Contents/MacOS/wind directly makes that dynamic
# validation fail even when `codesign --verify` accepts the bundle on disk.
if terminal_path="$(tty 2>/dev/null)" && [[ "$terminal_path" != "not a tty" ]]; then
  exec open -W --stdout "$terminal_path" --stderr "$terminal_path" "$bundle" --args "$@"
fi

# LaunchServices needs concrete output paths. Preserve diagnostics for
# non-interactive Cargo callers and replay them when the application exits.
stdout_log="$(mktemp "${TMPDIR:-/tmp}/wind-stdout.XXXXXX")"
stderr_log="$(mktemp "${TMPDIR:-/tmp}/wind-stderr.XXXXXX")"
cleanup_logs() {
  rm -f "$stdout_log" "$stderr_log"
}
trap cleanup_logs EXIT

set +e
open -W --stdout "$stdout_log" --stderr "$stderr_log" "$bundle" --args "$@"
open_status=$?
set -e
cat "$stdout_log"
cat "$stderr_log" >&2
exit "$open_status"
